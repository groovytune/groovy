generator client {
  provider        = "prisma-client"
  output          = "../src/lib/server/prisma"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

enum Privacy {
  PUBLIC
  PRIVATE
  UNLISTED
}

model User {
  id            String        @id
  name          String
  username      String?
  role          String        @default("user")
  email         String
  emailVerified Boolean       @default(false)
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  sessions      Session[]
  accounts      Account[]
  releases      Release[]
  streamed      Stream[]
  posts         Post[]
  likedReleases ReleaseLike[]
  likedTracks   TrackLike[]
  likedPosts    PostLike[]
  followers     UserFollow[]  @relation("UserFollowers")
  following     UserFollow[]  @relation("UserFollowing")

  @@unique([email])
  @@unique([username])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum ReleaseType {
  SINGLE
  ALBUM
  EP
}

model Release {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        ReleaseType
  name        String
  description String?
  privacy     Privacy       @default(PUBLIC)
  explicit    Boolean       @default(false)
  cover       String?
  tracks      Track[]
  genres      Genre[]       @relation("ReleaseGenres")
  likes       ReleaseLike[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([cover])
}

model Track {
  id        String   @id @default(cuid())
  position  Int      @default(1)
  releaseId String
  release   Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  name      String
  explicit  Boolean  @default(false)
  cover     String?
  file      String
  duration  Int?
  lyricsId  String?
  lyrics    Lyrics?
  genres    Genre[]  @relation("TrackGenres")
  streams   Stream[]
  likes     TrackLike[]
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cover])
  @@unique([file])
  @@unique([lyricsId])
}

enum LyricsFormat {
  LRC
  TTML
  LYS
  YRC
  LYL
  TXT
}

model Lyrics {
  id        String       @id @default(cuid())
  trackId   String
  track     Track        @relation(fields: trackId, references: id, onDelete: Cascade)
  format    LyricsFormat
  content   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([trackId])
}

model Genre {
  id        String    @id @default(cuid())
  name      String    @unique
  explicit  Boolean   @default(false)
  tracks    Track[]   @relation("TrackGenres")
  releases  Release[] @relation("ReleaseGenres")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Stream {
  id        String   @id @default(cuid())
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  hostname  String?
  userAgent String?
  createdAt DateTime @default(now())
}

model ReleaseLike {
  id        String   @id @default(cuid())
  releaseId String
  release   Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([releaseId, userId])
}

model TrackLike {
  id        String   @id @default(cuid())
  trackId   String
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([trackId, userId])
}

model UserFollow {
  id         String   @id @default(cuid())
  followerId String
  follower   User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation("UserFollowers", fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([followerId, userId])
}

model Post {
    id       String   @id @default(cuid())
    userId   String
    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    content  String
    referenceId String?
    reference   Post?    @relation("PostReference", fields: [referenceId], references: [id], onDelete: SetNull)
    likes    PostLike[]
    replies  Post[]   @relation("PostReference")
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model PostLike {
    id       String   @id @default(cuid())
    postId   String
    post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
    userId   String
    user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    createdAt DateTime @default(now())

    @@unique([postId, userId])
}
